# ============================================================
# WhatsLark — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ----- Supabase -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ----- Database (direct connection for migrations) -----
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----- API Server -----
API_PORT=3001
API_HOST=http://localhost:3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ----- Frontend -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=WhatsLark

# ----- WhatsApp Cloud API -----
# Obtained from Meta for Developers → your app
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_URL=https://graph.facebook.com
# Webhook verify token — any random string you choose
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-webhook-verify-token

# ----- Redis (BullMQ) -----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Or use a full URL: redis://:password@host:6379
REDIS_URL=redis://127.0.0.1:6379

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ----- Email (for transactional emails) -----
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@whatslark.com

# ----- Super Admin -----
SUPER_ADMIN_EMAIL=admin@whatslark.com
SUPER_ADMIN_PASSWORD=change-me-in-production

# ----- Rate Limiting -----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ----- ngrok (local webhook testing) -----
# Run: npx ngrok http 3001
# Then set NGROK_URL to your ngrok URL and update your Meta app webhook URL
NGROK_URL=https://xxxx.ngrok-free.app
